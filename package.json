{
  "name": "telegram-productivity-companion",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram Productivity Companion — Bot + Mini App с геймификацией, привычками и AI-коучингом",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:backend": "pnpm --filter @tpc/backend dev",
    "dev:miniapp": "pnpm --filter @tpc/miniapp dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @tpc/database generate",
    "db:migrate": "pnpm --filter @tpc/database migrate",
    "db:studio": "pnpm --filter @tpc/database studio",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
