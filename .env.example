# ──────────────────────────────────────────────────────────────
# Telegram Productivity Companion — пример переменных окружения
# Скопируй в .env и заполни.
# ──────────────────────────────────────────────────────────────

# Режим запуска backend-процесса.
# all  — один процесс поднимает HTTP API + бота + планировщик (по умолчанию на старте)
# api  — только REST API (для горизонтального масштабирования)
# bot  — только Telegram-бот
# worker — только планировщик/очереди
RUN_MODE=all

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────
# Внутри docker-compose host = "postgres"
DATABASE_URL=postgresql://tpc:tpc@localhost:5432/tpc?schema=public

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8835942754:AAFHYZS3YznWuty90kurfLZTqs1qSq1_7nc
# Для webhook-режима в продакшене (на старте можно polling):
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_DOMAIN=
TELEGRAM_WEBHOOK_SECRET=change-me-random
# URL Mini App (https), который бот открывает кнопкой
MINI_APP_URL=https://localhost:5173
# Троттлинг рассылки под лимит Telegram (≈30 msg/s на бота). Сглаживает почасовой
# всплеск рассылки, чтобы не ловить 429. 0 = без лимита (не рекомендуется на масштабе).
TELEGRAM_MAX_MSGS_PER_SEC=30
# Ёмкость «бакета» — допустимый мгновенный всплеск. По умолчанию = скорости.
TELEGRAM_SEND_BURST=30

# ── Auth (Mini App) ───────────────────────────────────────────
JWT_SECRET=change-me-long-random-string
JWT_TTL=15m

# Секрет для admin-эндпоинтов выдачи премиума (заголовок x-admin-token).
# Пусто = админка выключена. Пример выдачи:
#   curl -X POST https://<api>/api/admin/premium/grant -H "x-admin-token: $ADMIN_TOKEN" \
#        -H "Content-Type: application/json" -d '{"telegramId":123456,"days":30}'
ADMIN_TOKEN=

# CORS: Origin'ы фронта при кросс-доменном деплое (GitHub Pages).
# Через запятую, без слэша в конце. Пусто = выключено. Пример:
# CORS_ORIGINS=https://<username>.github.io
CORS_ORIGINS=

# ── Self-hosting через ngrok (см. SELF-HOSTING.md) ────────────
# Authtoken из дашборда ngrok: https://dashboard.ngrok.com/get-started/your-authtoken
# Нужен только при запуске:  docker compose --profile tunnel up -d
NGROK_AUTHTOKEN=

# ── AI (абстракция провайдера) ────────────────────────────────
# provider: openai | ollama | noop
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Для будущего self-hosted:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# AI-утро: персональный мотивационный текст в утренней рассылке (на основе стрика/
# привычек/скиллов). Строго opt-in и работает только при AI_PROVIDER != noop.
# false (по умолчанию) = шлём обычный статичный текст, токены не тратятся.
AI_MORNING_ENABLED=false
# Лимит времени на один LLM-вызов в тике (мс): превышение → фолбэк на статичный текст.
AI_MORNING_TIMEOUT_MS=4000
# Параллелизм генерации внутри тика (1..50): защита от шквала запросов под 100k+.
AI_MORNING_CONCURRENCY=4

# ── Расписание (таймзона по умолчанию для новых пользователей) ─
DEFAULT_TIMEZONE=Europe/Moscow
MORNING_HOUR=8
EVENING_HOUR=21

# Сдвиг "текущего времени" в минутах, если часы хоста идут неверно.
# Часы спешат на 3 часа → поставь -180. По умолчанию 0.
CLOCK_OFFSET_MINUTES=0
